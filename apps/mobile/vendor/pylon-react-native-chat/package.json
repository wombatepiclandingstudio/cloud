{
  "name": "@pylon/react-native-chat",
  "version": "0.1.0-kilo.1",
  "description": "Pylon Chat SDK for React Native",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "homepage": "https://github.com/usepylon/pylon-chat-sdk",
  "keywords": [
    "pylon",
    "chat",
    "react-native",
    "customer-support",
    "native-module"
  ],
  "author": "Pylon",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "codegenConfig": {
    "name": "RNPylonChatSpec",
    "type": "components",
    "jsSrcsDir": "src/specs",
    "android": {
      "javaPackageName": "com.pylonchat.reactnative"
    },
    "ios": {
      "componentProvider": {
        "RNPylonChatView": "RNPylonChatFabricView"
      }
    }
  },
  "files": [
    "lib",
    "src",
    "ios",
    "android",
    "RNPylonChat.podspec"
  ]
}