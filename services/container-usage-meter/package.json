{
  "name": "container-usage-meter",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "types": "wrangler types --include-runtime=false",
    "typecheck": "tsgo --noEmit",
    "lint": "pnpm -w exec oxlint --config .oxlintrc.json services/container-usage-meter/src",
    "test": "vitest run",
    "test:postgres": "vitest run --config vitest.postgres.config.ts"
  },
  "dependencies": {
    "@kilocode/container-usage": "workspace:*",
    "@kilocode/db": "workspace:*",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "jsonc-parser": "3.3.1",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
