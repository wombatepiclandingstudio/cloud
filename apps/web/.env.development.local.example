# @from BITBUCKET_OAUTH_CREDENTIAL_ACTIVE_PUBLIC_KEY
BITBUCKET_OAUTH_CREDENTIAL_ACTIVE_PUBLIC_KEY=

# JSON keyring with active and optional previous 32-64 byte base64 keys.
# @from BITBUCKET_CODE_REVIEW_WEBHOOK_SIGNING_KEYS
BITBUCKET_CODE_REVIEW_WEBHOOK_SIGNING_KEYS=

# Optional public HTTPS origin for Bitbucket Code Reviewer webhooks.
# Use an HTTPS tunnel to this Next.js app for local webhook setup.
# `pnpm dev:start code-review` writes this automatically. For a stable URL,
# configure TUNNEL_APP_HOSTNAME or BITBUCKET_CODE_REVIEW_WEBHOOK_HOSTNAME in
# ~/.config/kiloclaw/dev-start.conf or services/kiloclaw/scripts/.dev-start.conf.
BITBUCKET_CODE_REVIEW_WEBHOOK_BASE_URL=

