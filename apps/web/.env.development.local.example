# @url kilo-chat
NEXT_PUBLIC_KILO_CHAT_URL=http://localhost:8808

# Server-only destination for the cloud → kilo-chat internal call (carries the
# internal API key + prompt). Kept separate from the NEXT_PUBLIC_ var so the
# destination is never browser-exposed. Locally points at the same kilo-chat.
# @url kilo-chat
KILO_CHAT_INTERNAL_URL=http://localhost:8808

# @url event-service
NEXT_PUBLIC_EVENT_SERVICE_URL=ws://localhost:8809

# @url cloudflare-wasteland
NEXT_PUBLIC_WASTELAND_URL=http://localhost:8811

# KiloClaw legacy recognized Stripe price IDs (test values)
# Required so settlement, plan detection, and legacy intro repair continue to recognize pre-rollout subscriptions.
STRIPE_KILOCLAW_2026_03_19_STANDARD_INTRO_PRICE_ID=price_test_kiloclaw_2026_03_19_standard_intro
STRIPE_KILOCLAW_2026_03_19_STANDARD_PRICE_ID=price_test_kiloclaw_2026_03_19_standard
STRIPE_KILOCLAW_2026_03_19_COMMIT_PRICE_ID=price_test_kiloclaw_2026_03_19_commit
# KiloClaw current checkout Stripe price IDs (test values)
# Fresh current checkout uses recurring Standard immediately; no current Standard intro price is required.
STRIPE_KILOCLAW_2026_05_10_STANDARD_PRICE_ID=price_test_kiloclaw_2026_05_10_standard
STRIPE_KILOCLAW_2026_05_10_COMMIT_PRICE_ID=price_test_kiloclaw_2026_05_10_commit
